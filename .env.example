# get BRAK IdP values from 1Password by searching for "BRAK IdP"
BRAK_IDP_OIDC_CLIENT_ID=
BRAK_IDP_OIDC_CLIENT_SECRET=
BRAK_IDP_OIDC_ISSUER=https://schulung.bea-brak.de/auth/realms/brak
BRAK_IDP_OIDC_REDIRECT_URI=https://kompla.dev.tech.digitalservice.dev/auth/callback
ENVIRONMENT=development
E2E_BASE_URL=https://kompla.dev.tech.digitalservice.dev
# get basic auth credentials from 1Password by searching for "KomPla basic auth"
HTTP_CREDENTIALS_USERNAME=
HTTP_CREDENTIALS_PASSWORD=
KOMPLA_API_URL=https://app.kompla-justiz.sinc.de/main
# get KOMPLA IdP values from 1Password by searching for "KomPla IdP"
KOMPLA_IDP_CLIENT_ID=
KOMPLA_IDP_ISSUER=https://login.kompla-justiz.sinc.de/realms/kompla-dev
KOMPLA_IDP_SUBJECT_ISSUER=
# get KomPla Demo (Testzugang) values from 1Password by searching for "KomPla Demo"
# IdP base URL, e.g. https://auth.kompla-justiz.sinc.de/realms/kompla-dev
KOMPLA_DEMO_IDP_ISSUER=
# Service account for client_credentials grant (Step 1)
KOMPLA_DEMO_SERVICE_CLIENT_ID=magic-link-service
KOMPLA_DEMO_SERVICE_CLIENT_SECRET=
# Magic link client and callback (Step 2)
# redirect_uri must be registered in Keycloak; locally: http://localhost:3000/auth/magic-link-callback
KOMPLA_DEMO_CLIENT_ID=magic-link
KOMPLA_DEMO_REDIRECT_URI=http://localhost:3000/auth/magic-link-callback
KOMPLA_DEMO_USERNAME=demo
KOMPLA_DEMO_EMAIL=demo@kompla-justiz.de
SENTRY_DSN=

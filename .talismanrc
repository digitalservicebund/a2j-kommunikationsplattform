scopeconfig:

- scope: node # ignores files such as package-lock.json

allowed_patterns:

- key
- 'uses:\s\*[A-Za-z0-9_.-]+\/[A-Za-z0-9_.-]+@[a-fA-F0-9]{40}'
- TRIVY_PASSWORD:\ \${{\ secrets.GITHUB_TOKEN\ }}
- secrets:\ inherit
- password:\ \${{\ secrets.GITHUB_TOKEN\ }}
- HTTP_CREDENTIALS_PASSWORD:\ \${{\ secrets.HTTP_CREDENTIALS_PASSWORD\ }}
- getSecret\(\)
- clientSecret:\ \${{\ secrets.[A-Z0-9_]+ }}
- BRAK_IDP_OIDC_CLIENT_SECRET
- 'clientSecret:\s\*serverConfig\(\)\.BRAK_IDP_OIDC_CLIENT_SECRET'
- 'const getSecret = \(\) => \{'
- 'clientSecret:\s*serverConfig\(\).*'
- 'sonar\.projectKey=digitalservicebund_a2j-kommunikationsplattform'
- clientSecret:\ \"{{OAUTH_CLIENT_SECRET}}\"
- KOMPLA_DEMO_SERVICE_CLIENT_SECRET
- client_secret:\ this.config.serviceClientSecret

fileignoreconfig:

- filename: .github/workflows/sonarqube.yml
  checksum: e0ce0d0ad88a7f6b83e9dd8c6b03b164d55857518bda01e624cb283996fe0392
- filename: .github/workflows/pipeline.yml
  checksum: 2467c681462afc79cfb6ea894a70ac4d55479c5e94055124c2ffd87299e77ee1
- filename: .github/workflows/scan.yml
  checksum: 1582a4d97ed48f0cec201aab58ae536c4ba512dc933c45267dcd856b7e9b2f7e
- filename: .env.op
  checksum: ce5c604a92f2285c9b623235bd0ad6d8a3e494c617374bacba2934a95127baa6
- filename: .env.defaults
  checksum: ddb959b86f4ff32a615a6da54c14f4c04509bfc8ec58b34d0d9ab557fbf93167
- filename: app/config/**test**/config.server.test.ts
  checksum: bb34b6bf2a33760dfb871ec19b04b517ba769a29433dfed46bd2eb6cd0a98ec0
- filename: playwright.config.ts
  checksum: 64e5e6fe7a7787a6c84f3c8ac347e54a421c400c6982b46ee2b6d4dd4497af75
- filename: app/components/hooks/**test**/useLogoutInactiveUser.test.tsx
  ignore_detectors: [filecontent]
- filename: app/config/config.server.ts
  ignore_detectors: [filecontent]
- filename: app/services/auth/oAuth.server.ts
  ignore_detectors: [filecontent]
- filename: app/services/auth/**test**/authSession.server.test.ts
  ignore_detectors: [filecontent]
- filename: app/services/auth/**test**/oAuth.server.test.ts
  ignore_detectors: [filecontent]
- filename: app/services/auth/**test**/MagicLinkStrategy.server.test.ts
  ignore_detectors: [filecontent]
- filename: app/services/translations/de.ts
  ignore_detectors: [filecontent]
- filename: docs/HOW_TO_CONFIGURE_BRUNO.md
  ignore_detectors: [filecontent]
- filename: docs/DEVELOPMENT.md
  ignore_detectors: [filecontent]
- filename: README.md
  ignore_detectors: [filecontent]
